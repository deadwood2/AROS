
include $(SRCDIR)/config/aros.cfg
include $(SRCDIR)/workbench/libs/mesa/mesa.cfg

GALLIUM_PATH = $(top_srcdir)/src/gallium

include $(GALLIUM_PATH)/drivers/nouveau/Makefile.sources
include $(SRCDIR)/$(CURDIR)/sources.drm.mak

# WARNING - THIS MMAKEFILE REFERENCES SOURCE CODE OUTSIDE OF ITS TREE

# Currently only built for x86, because nouveau.hidd uses agp.hidd
# which fails to build on architectures due to because of missing
# Wbinvd() implementation.

#MM- workbench-hidds-nouveau : hidd-nouveau-$(AROS_TARGET_CPU)
#MM- hidd-nouveau-i386 : hidd-nouveau
#MM- hidd-nouveau-x86_64 : hidd-nouveau
#MM hidd-nouveau : hidd-nouveau-libdrm hidd-nouveau-drm hidd-i2c hidd-agp hidd-gallium

GALLIUM_NOUVEAU_SOURCES := \
            	$(C_SOURCES) \
            	$(NV30_C_SOURCES) \
            	$(NV50_CODEGEN_SOURCES) \
            	$(NV50_C_SOURCES) \
            	$(NVC0_CODEGEN_SOURCES) \
            	$(NVC0_C_SOURCES)

GALLIUM_NOUVEAU_C_SOURCES := \
            	$(filter %.c, $(GALLIUM_NOUVEAU_SOURCES))

GALLIUM_NOUVEAU_CXX_SOURCES := \
            	$(filter %.cpp, $(GALLIUM_NOUVEAU_SOURCES))

#NOUVEAU_HIDD_CXX_SOURCES := \
#            $(addprefix $(GALLIUM_PATH)/drivers/nouveau/, $(GALLIUM_NOUVEAU_CXX_SOURCES:.cpp=))

#            -iquote $(GALLIUM_PATH)/drivers \
#            -iquote $(GALLIUM_PATH)/drivers/nouveau \
#            -iquote $(GALLIUM_PATH)/include \
#            -iquote $(GALLIUM_PATH)/auxiliary \
#            -iquote $(top_srcdir)/src/mesa \
#            -iquote $(GENDIR)/workbench/libs/mesa/src/compiler/nir \

#FIXME
#            nouveau_galliumclass \
#            $(addprefix $(GALLIUM_PATH)/drivers/nouveau/, $(GALLIUM_NOUVEAU_C_SOURCES:.c=)) \

###############################################
# drm, drm-aros, drm-compat -> libdrm_nouveau.a
###############################################

USER_INCLUDES := \
            -I$(SRCDIR)/$(CURDIR)/include \
            -I$(SRCDIR)/$(CURDIR)/drm/nouveau \
            -I$(SRCDIR)/$(CURDIR)/drm/nouveau/include \
            -I$(SRCDIR)/$(CURDIR)/drm/nouveau/include/nvkm \
            -I$(SRCDIR)/$(CURDIR)/drm/nouveau/nvkm \

NOUVEAU_DRM_C_SOURCES := \
            $(addprefix $(SRCDIR)/$(CURDIR)/,$(AROS_DRM_NVIDIA_SOURCES)) \
            $(addprefix $(SRCDIR)/$(CURDIR)/,$(AROS_DRM_CORE_SOURCES))

%build_linklib mmake=hidd-nouveau-drm libname=drm_nouveau files="$(NOUVEAU_DRM_C_SOURCES)" sdk=drm usesdks="config private"

#################################################
# xf86-video-nouveau + hidd codes -> nouveau.hidd
#################################################

XF86_NOUVEAU_SOURCES = \
            nv_accel_common \
            nv50_accel \
            nv40_exa \
            nv30_exa \
            nv10_exa \
            nv50_exa \
            nouveau_exa \
            nvc0_accel \
            nvc0_exa \
            nv04_exa \
            nouveau_xv \
            nouveau_copya0b5 \

XF86_NOUVEAU_PATH = $(SRCDIR)/$(CURDIR)/xf86-video-nouveau/

NOUVEAU_HIDD_C_SOURCES := \
            nouveau_hiddclass \
            nouveau_init \
            nouveau_bitmapclass \
            nouveau_accel \
            nouveau_i2cclass \
            nouveau_compositorclass \
            $(addprefix $(XF86_NOUVEAU_PATH), $(XF86_NOUVEAU_SOURCES))  \

USER_INCLUDES := \
            -I$(XF86_NOUVEAU_PATH) \
            -I$(SRCDIR)/$(CURDIR)/include \
            -I$(SRCDIR)/$(CURDIR)/include/libdrm/nouveau \

NOWARN_FLAGS := $(NOWARN_UNINITIALIZED) $(NOWARN_STRICT_ALIASING)
USER_CFLAGS += $(NOWARN_FLAGS) -std=gnu99

USER_LDFLAGS += \
  -lstdlib -lcrtmod -lcrt
  
%build_module mmake=hidd-nouveau modname=nouveau modtype=hidd \
    files="$(NOUVEAU_HIDD_C_SOURCES)" cxxfiles="$(NOUVEAU_HIDD_CXX_SOURCES)" \
    uselibs="oop libdrm_nouveau drm_nouveau pthread hiddstubs crtmod crt" usesdks="config private mesa drm"
